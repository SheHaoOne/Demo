<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <!-- 默认加载亮色主题画刷（运行时由 ThemeManager 动态替换） -->
        <ResourceDictionary Source="pack://application:,,,/FlowDesk.UI;component/Themes/Light.xaml" />
        <!-- 引用主题画刷的控件样式 -->
        <ResourceDictionary Source="pack://application:,,,/FlowDesk.UI;component/Themes/ControlStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
