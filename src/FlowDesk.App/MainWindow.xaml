<Window x:Class="FlowDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlowDesk" Height="720" Width="1120" MinHeight="600" MinWidth="960"
        Background="{DynamicResource AppBackgroundBrush}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="工作流:" FontWeight="SemiBold" Margin="0,0,8,8" />
            <TextBox Width="280"
                     Margin="0,0,12,8"
                     Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="新建" Command="{Binding NewCommand}" />
            <Button Content="打开" Command="{Binding OpenCommand}" />
            <Button Content="保存" Command="{Binding SaveCommand}" />
            <Button Content="运行" Command="{Binding RunCommand}"
                    Style="{DynamicResource PrimaryButton}" />
            <TextBlock Text="{Binding Status}" Margin="8,0,0,8"
                       Foreground="{DynamicResource SecondaryTextBrush}" />

            <!-- 主题切换按钮，靠右对齐 -->
            <Button Content="{Binding ThemeLabel}"
                    Command="{Binding ToggleThemeCommand}"
                    HorizontalAlignment="Right"
                    Margin="16,0,0,8" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="180" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Column="0" Grid.RowSpan="2" Header="可用插件">
                <DockPanel Margin="8">
                    <Button DockPanel.Dock="Bottom"
                            Content="添加到工作流"
                            Command="{Binding AddPluginCommand}"
                            Style="{DynamicResource PrimaryButton}" />
                    <ListBox ItemsSource="{Binding Plugins}"
                             SelectedItem="{Binding SelectedPlugin}"
                             DisplayMemberPath="DisplayName" />
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="序列编辑器">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                        <Button Content="上移" Command="{Binding MoveStepUpCommand}" />
                        <Button Content="下移" Command="{Binding MoveStepDownCommand}" />
                        <Button Content="移除" Command="{Binding RemoveStepCommand}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Steps}"
                             SelectedItem="{Binding SelectedStep}"
                             DisplayMemberPath="DisplayName" />
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="4" Header="步骤设置">
                <DataGrid ItemsSource="{Binding SelectedStepSettings}"
                          Margin="8"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="键" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="1" Header="执行日志" Margin="0,12,0,0">
                <ListBox ItemsSource="{Binding ExecutionLog}" Margin="8" />
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
