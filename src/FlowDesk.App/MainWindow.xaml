<Window x:Class="FlowDesk.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlowDesk.App.ViewModels"
        xmlns:v="clr-namespace:FlowDesk.App.Views"
        Title="FlowDesk" Height="780" Width="1200" MinHeight="600" MinWidth="960"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 页面 ViewModel → View 映射 -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <v:HomePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <v:ConfigPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SequenceEditorViewModel}">
            <v:SequenceEditorPage />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- ===== 顶部标题栏 ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PrimaryBrush}" Padding="16,10">
            <DockPanel>
                <TextBlock Text="FlowDesk" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryForegroundOnAccentBrush}"
                           DockPanel.Dock="Left" VerticalAlignment="Center" />

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <!-- 菜单位置切换 -->
                    <TextBlock Text="菜单位置:" Foreground="{DynamicResource PrimaryForegroundOnAccentBrush}"
                               Margin="0,0,6,0" />
                    <Button Content="左" Margin="0,0,2,0" Padding="8,4"
                            Command="{Binding SetMenuPositionCommand}" CommandParameter="Left" />
                    <Button Content="顶" Margin="0,0,2,0" Padding="8,4"
                            Command="{Binding SetMenuPositionCommand}" CommandParameter="Top" />
                    <Button Content="底" Margin="0,0,12,0" Padding="8,4"
                            Command="{Binding SetMenuPositionCommand}" CommandParameter="Bottom" />
                    <!-- 主题切换 -->
                    <Button Content="{Binding ThemeLabel}" Command="{Binding ToggleThemeCommand}"
                            Padding="8,4" Margin="0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 导航菜单（左侧时） ===== -->
        <Border x:Name="LeftNavPanel" DockPanel.Dock="Left" Width="180"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MenuPosition}" Value="Left">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ListBox ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNavItem}"
                     Background="Transparent" BorderThickness="0" Margin="0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="12,8">
                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Margin="0,0,10,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Label}" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ===== 导航菜单（顶部时） ===== -->
        <Border x:Name="TopNavPanel" DockPanel.Dock="Top"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MenuPosition}" Value="Top">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ListBox ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNavItem}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="16,8">
                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Label}" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ===== 导航菜单（底部时） ===== -->
        <Border x:Name="BottomNavPanel" DockPanel.Dock="Bottom"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MenuPosition}" Value="Bottom">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ListBox ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNavItem}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="20,8">
                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Label}" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ===== 内容显示区域 ===== -->
        <ContentControl Content="{Binding CurrentPage}" />

    </DockPanel>
</Window>
