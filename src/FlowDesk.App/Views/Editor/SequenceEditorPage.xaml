<UserControl x:Class="FlowDesk.App.Views.Editor.SequenceEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:editor="clr-namespace:FlowDesk.App.ViewModels.Editor"
             xmlns:pe="clr-namespace:FlowDesk.App.ViewModels.Editor.PropertyEditors"
             x:Name="EditorRoot">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <WrapPanel>
                <TextBlock Text="序列名称:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBox Width="200" Margin="0,0,12,0"
                         Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="新建" Command="{Binding NewCommand}" />
                <Button Content="打开" Command="{Binding OpenCommand}" />
                <Button Content="保存" Command="{Binding SaveCommand}" />
                <Button Content="另存为" Command="{Binding SaveAsCommand}" />
                <Button Content="发送到首页运行" Command="{Binding SendToHomeCommand}"
                        Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" />
            </WrapPanel>
        </Border>

        <!-- 主编辑区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：步骤分类（Expander 展开显示步骤卡片，支持拖拽） -->
            <GroupBox Grid.Column="0" Header="可用步骤">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl ItemsSource="{Binding PluginCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="True" Margin="0,0,0,8">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Plugins}" Margin="4,4,4,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="8,8" Margin="2" Cursor="Hand"
                                                        MouseMove="PluginCard_MouseMove"
                                                        MouseLeftButtonDown="PluginCard_Click"
                                                        ToolTip="{Binding Description}">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="{Binding Icon}"
                                                                   FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource PrimaryBrush}" />
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="10"
                                                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- 中间：序列树状列表（支持拖拽放置） -->
            <GroupBox Grid.Column="2" Header="工作流序列">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="上移" Command="{Binding MoveStepUpCommand}" />
                        <Button Content="下移" Command="{Binding MoveStepDownCommand}" />
                        <Button Content="移除" Command="{Binding RemoveStepCommand}" />
                        <Button Content="新建分组" Command="{Binding AddGroupCommand}" />
                        <Button Content="添加选中插件" Command="{Binding AddPluginCommand}"
                                Style="{DynamicResource PrimaryButton}" />
                    </StackPanel>
                    <TreeView BorderThickness="0" Background="Transparent"
                              ItemsSource="{Binding Steps}"
                              SelectedItemChanged="StepTree_SelectedItemChanged"
                              AllowDrop="True"
                              DragOver="StepTree_DragOver"
                              Drop="StepTree_Drop">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,4">
                                    <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,6,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding PluginId, StringFormat='  [{0}]'}"
                                               Foreground="{DynamicResource HintTextBrush}" FontSize="11" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </GroupBox>

            <!-- 右侧：步骤属性编辑器 -->
            <GroupBox Grid.Column="4" Header="步骤设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl ItemsSource="{Binding SelectedStepPropertyEditors}">
                        <ItemsControl.Resources>
                            <!-- 字符串编辑器 -->
                            <DataTemplate DataType="{x:Type pe:StringPropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- 整数编辑器 -->
                            <DataTemplate DataType="{x:Type pe:IntegerPropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- 浮点数编辑器 -->
                            <DataTemplate DataType="{x:Type pe:DoublePropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- 布尔编辑器 -->
                            <DataTemplate DataType="{x:Type pe:BooleanPropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <CheckBox IsChecked="{Binding Value}" Content="{Binding Description}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- 枚举编辑器 -->
                            <DataTemplate DataType="{x:Type pe:EnumPropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <ComboBox ItemsSource="{Binding Options}"
                                              SelectedValue="{Binding StringValue}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                            <!-- 文件路径编辑器 -->
                            <DataTemplate DataType="{x:Type pe:FilePathPropertyEditorViewModel}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" />
                                    <DockPanel Margin="0,4,0,0">
                                        <Button Content="..." DockPanel.Dock="Right" Width="30" Margin="4,0,0,0" />
                                        <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.Resources>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
