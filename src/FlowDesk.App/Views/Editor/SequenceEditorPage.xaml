<UserControl x:Class="FlowDesk.App.Views.Editor.SequenceEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:editor="clr-namespace:FlowDesk.App.ViewModels.Editor"
             x:Name="EditorRoot">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <WrapPanel>
                <TextBlock Text="序列名称:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBox Width="200" Margin="0,0,12,0"
                         Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="新建" Command="{Binding NewCommand}" />
                <Button Content="打开" Command="{Binding OpenCommand}" />
                <Button Content="保存" Command="{Binding SaveCommand}" />
                <Button Content="另存为" Command="{Binding SaveAsCommand}" />
                <Button Content="发送到首页运行" Command="{Binding SendToHomeCommand}"
                        Style="{DynamicResource PrimaryButton}" Margin="8,0,0,0" />
            </WrapPanel>
        </Border>

        <!-- 主编辑区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：步骤分类卡片（图标+类名，悬浮显示步骤列表） -->
            <GroupBox Grid.Column="0" Header="可用步骤">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl ItemsSource="{Binding PluginCategories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Width="100" Height="90"
                                        Margin="4" Cursor="Hand"
                                        ToolTipService.ShowDuration="30000"
                                        ToolTipService.InitialShowDelay="200">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="28"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryBrush}" />
                                        <TextBlock Text="{Binding Category}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" Margin="0,6,0,0" />
                                    </StackPanel>
                                    <!-- 悬浮弹出：3 列步骤列表 -->
                                    <Border.ToolTip>
                                        <ToolTip MaxWidth="420">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Category}" FontWeight="Bold"
                                                           FontSize="13" Margin="0,0,0,8" />
                                                <ItemsControl ItemsSource="{Binding Plugins}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="3" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="Transparent"
                                                                    BorderBrush="{DynamicResource BorderLightBrush}"
                                                                    BorderThickness="1" CornerRadius="4"
                                                                    Padding="8,6" Margin="2" Cursor="Hand"
                                                                    MouseLeftButtonDown="PluginCard_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="14" Margin="0,0,6,0"
                                                                               Foreground="{DynamicResource PrimaryBrush}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- 中间：序列树状列表 -->
            <GroupBox Grid.Column="2" Header="工作流序列">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="上移" Command="{Binding MoveStepUpCommand}" />
                        <Button Content="下移" Command="{Binding MoveStepDownCommand}" />
                        <Button Content="移除" Command="{Binding RemoveStepCommand}" />
                        <Button Content="新建分组" Command="{Binding AddGroupCommand}" />
                        <Button Content="添加选中插件" Command="{Binding AddPluginCommand}"
                                Style="{DynamicResource PrimaryButton}" />
                    </StackPanel>
                    <TreeView BorderThickness="0" Background="Transparent"
                              ItemsSource="{Binding Steps}"
                              SelectedItemChanged="StepTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,4">
                                    <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,6,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding PluginId, StringFormat='  [{0}]'}"
                                               Foreground="{DynamicResource HintTextBrush}" FontSize="11" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </GroupBox>

            <!-- 右侧：步骤设置 -->
            <GroupBox Grid.Column="4" Header="步骤设置">
                <DataGrid ItemsSource="{Binding SelectedStepSettings}" Margin="4"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="键" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
