<UserControl x:Class="FlowDesk.App.Views.ConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="系统配置" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="保存配置" Command="{Binding SaveCommand}"
                    Style="{DynamicResource PrimaryButton}"
                    HorizontalAlignment="Right" Margin="0" />
        </DockPanel>

        <!-- 配置选项卡 -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="系统配置">
                <DataGrid ItemsSource="{Binding SystemConfig}" Margin="8"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置项" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="PLC 配置">
                <DataGrid ItemsSource="{Binding PlcConfig}" Margin="8"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置项" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="采集卡配置">
                <DataGrid ItemsSource="{Binding DaqConfig}" Margin="8"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置项" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="传感器配置">
                <DataGrid ItemsSource="{Binding SensorConfig}" Margin="8"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="配置项" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
