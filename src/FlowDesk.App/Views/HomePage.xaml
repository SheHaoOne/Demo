<UserControl x:Class="FlowDesk.App.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="序列:" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding SequenceName}" Margin="0,0,16,0"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                    <Button Content="运行" Command="{Binding RunCommand}"
                            Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0" />
                    <Button Content="停止" Command="{Binding StopCommand}" Margin="0,0,8,0" />
                </StackPanel>
                <TextBlock Text="{Binding Status}" HorizontalAlignment="Right"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </DockPanel>
        </Border>

        <!-- 步骤状态树状表格 -->
        <GroupBox Grid.Row="1" Header="步骤执行状态">
            <TreeView ItemsSource="{Binding StepNodes}" BorderThickness="0" Background="Transparent">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid Margin="2,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="Medium" />
                            <Border Grid.Column="1" CornerRadius="2" Padding="6,2" HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryLightBrush}">
                                <TextBlock Text="{Binding Status}" FontSize="11" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding Duration}"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" />
                            <TextBlock Grid.Column="3" Text="{Binding Message}"
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </GroupBox>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="3" Header="执行日志">
            <ListBox ItemsSource="{Binding LogEntries}" BorderThickness="0"
                     Background="Transparent" FontFamily="Consolas, Microsoft YaHei UI"
                     FontSize="12" />
        </GroupBox>
    </Grid>
</UserControl>
