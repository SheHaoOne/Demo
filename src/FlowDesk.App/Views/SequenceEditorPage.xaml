<UserControl x:Class="FlowDesk.App.Views.SequenceEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="序列名称:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBox Width="240" Margin="0,0,12,0"
                         Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="发送到首页运行" Command="{Binding SendToHomeCommand}"
                        Style="{DynamicResource PrimaryButton}" Margin="0" />
            </StackPanel>
        </Border>

        <!-- 主编辑区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：插件分类卡片 -->
            <GroupBox Grid.Column="0" Header="可用步骤">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <ItemsControl ItemsSource="{Binding PluginCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Header="{Binding Category}" IsExpanded="True" Margin="0,0,0,8">
                                    <ItemsControl ItemsSource="{Binding Plugins}" Margin="4,4,4,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="12,10" Margin="0,0,0,6" Cursor="Hand"
                                                        MouseLeftButtonDown="PluginCard_Click">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel Grid.Row="0">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                                       DockPanel.Dock="Left" />
                                                            <TextBlock Text="{Binding Version}" FontSize="10"
                                                                       Foreground="{DynamicResource HintTextBrush}"
                                                                       HorizontalAlignment="Right" />
                                                        </DockPanel>
                                                        <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- 中间：序列树状列表 -->
            <GroupBox Grid.Column="2" Header="工作流序列">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="上移" Command="{Binding MoveStepUpCommand}" />
                        <Button Content="下移" Command="{Binding MoveStepDownCommand}" />
                        <Button Content="移除" Command="{Binding RemoveStepCommand}" />
                        <Button Content="添加选中插件" Command="{Binding AddPluginCommand}"
                                Style="{DynamicResource PrimaryButton}" />
                    </StackPanel>
                    <TreeView ItemsSource="{Binding Steps}" BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="StepTree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2,4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding PluginId, StringFormat='  [{0}]'}"
                                               Foreground="{DynamicResource HintTextBrush}" FontSize="11" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </GroupBox>

            <!-- 右侧：步骤设置 -->
            <GroupBox Grid.Column="4" Header="步骤设置">
                <DataGrid ItemsSource="{Binding SelectedStepSettings}" Margin="4"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="键" Binding="{Binding Key}" IsReadOnly="True" Width="*" />
                        <DataGridTextColumn Header="值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
