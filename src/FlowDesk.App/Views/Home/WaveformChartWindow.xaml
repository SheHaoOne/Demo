<Window x:Class="FlowDesk.App.Views.Home.WaveformChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TDMS 波形图" Height="600" Width="900" MinHeight="400" MinWidth="600"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题和文件信息 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="TDMS 波形数据" FontSize="18" FontWeight="Bold" />
            <TextBlock x:Name="FilePathText" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- 波形绘图区域 -->
        <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" ClipToBounds="True">
            <Grid>
                <Canvas x:Name="ChartCanvas" Margin="50,20,20,40"
                        SizeChanged="ChartCanvas_SizeChanged" />
                <!-- Y 轴标签 -->
                <Canvas x:Name="YAxisCanvas" Width="50" HorizontalAlignment="Left" Margin="0,20,0,40" />
                <!-- X 轴标签 -->
                <Canvas x:Name="XAxisCanvas" Height="40" VerticalAlignment="Bottom" Margin="50,0,20,0" />
            </Grid>
        </Border>

        <!-- 通道选择 -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="通道:" FontWeight="SemiBold" DockPanel.Dock="Left" Margin="0,0,8,0" />
                <ItemsControl x:Name="ChannelList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
