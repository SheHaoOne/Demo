<Window x:Class="FlowDesk.App.Views.Home.WaveformChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="TDMS 波形图" Height="650" Width="1000" MinHeight="400" MinWidth="600"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题和文件信息 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="TDMS 波形数据" FontSize="18" FontWeight="Bold" />
            <TextBlock x:Name="FilePathText" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ScottPlot 波形绘图区域 -->
        <sp:WpfPlot x:Name="WpfPlot" Grid.Row="1" />

        <!-- 通道选择 -->
        <Border Grid.Row="2" Margin="0,8,0,0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="4" Padding="12,8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="通道:" FontWeight="SemiBold" DockPanel.Dock="Left" Margin="0,0,8,0" />
                <ItemsControl x:Name="ChannelList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
